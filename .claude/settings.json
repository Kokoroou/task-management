{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pip install -e .[dev]",
            "statusMessage": "Updating dev dependencies..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$ARGUMENTS\" | grep -qE \"(rm -rf|drop database|kubectl delete|docker rm)\"; then echo 'SECURITY WARNING: Command blocked by Local Hook!' && exit 2; else exit 0; fi",
            "statusMessage": "Checking Bash security rules..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ruff check --fix $ARGUMENTS && ruff format $ARGUMENTS",
            "statusMessage": "Formatting with Ruff..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "mypy .",
            "statusMessage": "Running Type Check..."
          },
          {
            "type": "command",
            "command": "pytest tests/ --cov=task_engine",
            "statusMessage": "Running Unit Tests..."
          }
        ]
      }
    ]
  }
}
